# Vercel AI SDK Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Postgres
POSTGRES_URLPGSQL=postgresql://user:password@host:5432/database

# Vercel KV (Redis)
