# ============================================================
# ROSTR Agent Framework — Environment Configuration
# ============================================================
# BYOK (Bring Your Own Keys) — only add the keys you have.
# ROSTR works with any combination.

# ── LLM Providers ──────────────────────────────────────────
# At least one is required for chat. OpenAI recommended for embeddings.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=
GROQ_API_KEY=gsk_...

# Ollama (Local Free LLMs)
USE_OLLAMA=false
OLLAMA_MODEL=phi3
OLLAMA_ENDPOINT=http://localhost:11434/api/chat

# ── Agent Configuration ────────────────────────────────────
AGENT_NAME=ROSTR
AGENT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Server ─────────────────────────────────────────────────
GATEWAY_PORT=3001
DASHBOARD_PORT=3000

# ── Brain ──────────────────────────────────────────────────
BRAIN_PATH=.rostr-data
